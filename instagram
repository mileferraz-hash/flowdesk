<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1"/>
<title>Instagram KPIs — Flowdesk</title>
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&display=swap" rel="stylesheet"/>
<script src="https://www.gstatic.com/firebasejs/9.23.0/firebase-app-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/9.23.0/firebase-firestore-compat.js"></script>
<style>
:root{--purple:#6c63ff;--pl:#8b85ff;--pink:#e1306c;--orange:#f97316;--success:#22c55e;--danger:#ef4444;--warn:#f59e0b;--text:#1a1a2e;--text2:#6b7280;--text3:#9ca3af;--bg:#f4f5f9;--bg2:#fff;--bg3:#f8f8fc;--border:#e5e7eb;--r:12px;--rxl:20px;--shadow:0 2px 12px rgba(0,0,0,.07);}
*{box-sizing:border-box;margin:0;padding:0;}
body{font-family:'Poppins',sans-serif;background:var(--bg);color:var(--text);font-size:14px;}
.wrap{max-width:1100px;margin:0 auto;padding:28px 20px;}
h1{font-size:22px;font-weight:800;margin-bottom:4px;display:flex;align-items:center;gap:10px;}
.sub{font-size:13px;color:var(--text2);margin-bottom:24px;}
.top-bar{display:flex;gap:12px;align-items:center;flex-wrap:wrap;margin-bottom:24px;}
.top-bar select,.top-bar input{background:var(--bg2);border:1.5px solid var(--border);border-radius:var(--r);padding:9px 14px;font-size:13px;font-family:'Poppins',sans-serif;color:var(--text);cursor:pointer;}
.top-bar select:focus,.top-bar input:focus{outline:none;border-color:var(--purple);}
.btn{display:inline-flex;align-items:center;gap:7px;padding:9px 20px;border-radius:30px;font-size:13px;font-weight:600;cursor:pointer;border:none;transition:all .2s;font-family:'Poppins',sans-serif;}
.btn:hover{transform:translateY(-2px);}
.btn-primary{background:linear-gradient(135deg,var(--purple),var(--pl));color:#fff;box-shadow:0 4px 16px rgba(108,99,255,.3);}
.btn-ghost{background:var(--bg3);color:var(--text2);border:1.5px solid var(--border);}
.btn-ghost:hover{border-color:var(--purple);color:var(--purple);}
.card{background:var(--bg2);border:1.5px solid var(--border);border-radius:var(--rxl);box-shadow:var(--shadow);margin-bottom:18px;}
.card-header{padding:16px 20px 12px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;}
.card-title{font-size:13px;font-weight:700;}
.card-body{padding:16px 20px;}
.metrics{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-bottom:18px;}
@media(max-width:700px){.metrics{grid-template-columns:1fr 1fr;}.grid2{grid-template-columns:1fr!important;}.grid3{grid-template-columns:1fr!important;}}
.mcard{background:var(--bg2);border:1.5px solid var(--border);border-radius:var(--rxl);padding:18px;position:relative;overflow:hidden;box-shadow:var(--shadow);}
.mcard::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;}
.acc-pink::before{background:linear-gradient(90deg,#e1306c,#833ab4);}
.acc-purple::before{background:linear-gradient(90deg,var(--purple),var(--pl));}
.acc-orange::before{background:linear-gradient(90deg,var(--orange),#ea580c);}
.acc-green::before{background:linear-gradient(90deg,var(--success),#16a34a);}
.micon{width:38px;height:38px;border-radius:11px;display:flex;align-items:center;justify-content:center;font-size:18px;margin-bottom:12px;}
.mi-pink{background:rgba(225,48,108,.12);}
.mi-purple{background:rgba(108,99,255,.12);}
.mi-orange{background:rgba(249,115,22,.12);}
.mi-green{background:rgba(34,197,94,.12);}
.mlabel{font-size:10px;color:var(--text3);font-weight:700;text-transform:uppercase;letter-spacing:.06em;margin-bottom:4px;}
.mval{font-size:24px;font-weight:800;letter-spacing:-.5px;}
.msub{font-size:11px;color:var(--text2);margin-top:4px;}
.grid2{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:18px;}
.grid3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:16px;margin-bottom:18px;}
.hl{display:flex;align-items:center;justify-content:space-between;padding:10px 0;border-bottom:1px solid var(--border);}
.hl:last-child{border-bottom:none;}
.hl-lbl{font-size:12px;color:var(--text2);font-weight:500;}
.hl-val{font-size:13px;font-weight:700;color:var(--purple);}
.bar-row{display:flex;align-items:center;gap:10px;margin-bottom:11px;}
.bar-lbl{font-size:12px;color:var(--text2);width:70px;flex-shrink:0;}
.bar-wrap{flex:1;background:var(--bg3);border-radius:20px;height:8px;overflow:hidden;}
.bar-fill{height:100%;border-radius:20px;}
.bar-val{font-size:11px;color:var(--text2);width:55px;text-align:right;flex-shrink:0;font-weight:600;}
.month-bars{display:flex;align-items:flex-end;gap:6px;height:100px;margin-top:10px;}
.mb-wrap{flex:1;display:flex;flex-direction:column;align-items:center;gap:4px;}
.mb-bar{width:100%;border-radius:6px 6px 0 0;min-height:3px;}
.mb-lbl{font-size:9px;color:var(--text3);font-weight:600;}
.mb-val{font-size:9px;color:var(--text2);font-weight:700;}
.insight{display:flex;gap:10px;padding:9px 0;border-bottom:1px solid var(--border);}
.insight:last-child{border-bottom:none;}
.insight-icon{font-size:16px;flex-shrink:0;}
.insight-txt{font-size:12px;font-weight:500;line-height:1.5;}
.empty{text-align:center;padding:60px 20px;color:var(--text3);}
.empty-icon{font-size:48px;margin-bottom:12px;}
.empty-title{font-size:16px;font-weight:700;color:var(--text);margin-bottom:6px;}
table{width:100%;border-collapse:collapse;font-size:12px;}
th{padding:9px 8px;text-align:left;color:var(--text3);font-weight:700;border-bottom:2px solid var(--border);}
td{padding:9px 8px;border-bottom:1px solid var(--border);}
tr:last-child td{border-bottom:none;}
.modal-bg{position:fixed;inset:0;background:rgba(15,15,35,.5);display:flex;align-items:center;justify-content:center;z-index:100;backdrop-filter:blur(5px);}
.modal{background:var(--bg2);border:1.5px solid var(--border);border-radius:var(--rxl);padding:26px;width:560px;max-width:96vw;max-height:92vh;overflow-y:auto;box-shadow:0 20px 60px rgba(108,99,255,.2);}
.modal-title{font-size:17px;font-weight:700;margin-bottom:20px;}
.fg{margin-bottom:14px;}
.fl{font-size:10px;color:var(--text3);margin-bottom:5px;display:block;font-weight:700;text-transform:uppercase;letter-spacing:.07em;}
.fi{width:100%;background:var(--bg3);border:1.5px solid var(--border);border-radius:var(--r);color:var(--text);padding:10px 13px;font-size:13px;font-family:'Poppins',sans-serif;transition:all .18s;}
.fi:focus{outline:none;border-color:var(--purple);background:#fff;box-shadow:0 0 0 3px rgba(108,99,255,.1);}
.fr{display:grid;grid-template-columns:1fr 1fr;gap:12px;}
.fa{display:flex;gap:10px;justify-content:flex-end;margin-top:20px;flex-wrap:wrap;}
.section-box{background:var(--bg3);border:1.5px solid var(--border);border-radius:var(--r);padding:14px;margin-bottom:14px;}
.section-box-title{font-size:10px;color:var(--text3);font-weight:700;text-transform:uppercase;letter-spacing:.07em;margin-bottom:12px;}
.status-bar{display:flex;align-items:center;gap:8px;padding:8px 12px;background:var(--bg3);border-radius:var(--r);margin-bottom:16px;font-size:12px;}
.dot{width:8px;height:8px;border-radius:50%;background:var(--text3);flex-shrink:0;}
.dot.on{background:var(--success);}
.hidden{display:none!important;}
</style>
</head>
<body>
<div class="wrap">
  <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;margin-bottom:4px;">
    <h1>📱 Instagram KPIs</h1>
    <div class="status-bar"><div class="dot" id="fb-dot"></div><span id="fb-txt">Conectando...</span></div>
  </div>
  <div class="sub">Métricas mensais por cliente</div>

  <div class="top-bar">
    <select id="sel-client" onchange="onSelChange()"><option value="">— Selecione o cliente —</option></select>
    <select id="sel-month" onchange="onSelChange()"></select>
    <button class="btn btn-primary" onclick="openModal()">＋ Inserir / Editar dados</button>
    <a href="/" class="btn btn-ghost">← Voltar ao Flowdesk</a>
  </div>

  <!-- Empty state -->
  <div id="ig-empty" class="empty">
    <div class="empty-icon">📊</div>
    <div class="empty-title">Nenhum dado encontrado</div>
    <div>Selecione um cliente e clique em "＋ Inserir dados"</div>
  </div>

  <!-- Dashboard -->
  <div id="ig-dash" class="hidden">
    <!-- Métricas principais -->
    <div class="metrics">
      <div class="mcard acc-pink"><div class="micon mi-pink">👁️</div><div class="mlabel">Visualizações gerais</div><div class="mval" id="d-views" style="color:#e1306c">—</div><div class="msub" id="d-views-sub">—</div></div>
      <div class="mcard acc-purple"><div class="micon mi-purple">👥</div><div class="mlabel">Contas alcançadas</div><div class="mval t-purple" id="d-alcance" style="color:var(--purple)">—</div></div>
      <div class="mcard acc-orange"><div class="micon mi-orange">❤️</div><div class="mlabel">Engajamento</div><div class="mval" id="d-eng" style="color:#f56040">—</div><div class="msub" id="d-eng-taxa">—</div></div>
      <div class="mcard acc-green"><div class="micon mi-green">➕</div><div class="mlabel">Novos seguidores</div><div class="mval" id="d-seg" style="color:var(--success)">—</div></div>
    </div>

    <div class="grid2">
      <!-- Evolução -->
      <div class="card">
        <div class="card-header"><div class="card-title">📈 Evolução (últimos 6 meses)</div></div>
        <div class="card-body" id="d-evolution"></div>
      </div>
      <!-- Insights -->
      <div class="card">
        <div class="card-header"><div class="card-title">💡 Insights estratégicos</div></div>
        <div class="card-body" id="d-insights"></div>
      </div>
    </div>

    <div class="grid3">
      <div class="card">
        <div class="card-header"><div class="card-title">👥 Crescimento</div></div>
        <div class="card-body" id="d-growth"></div>
      </div>
      <div class="card">
        <div class="card-header"><div class="card-title">❤️ Engajamento</div></div>
        <div class="card-body" id="d-engagement"></div>
      </div>
      <div class="card">
        <div class="card-header"><div class="card-title">🌍 Alcance</div></div>
        <div class="card-body" id="d-reach"></div>
      </div>
    </div>

    <!-- Top post -->
    <div class="card">
      <div class="card-header"><div class="card-title">🏆 Post com maior visualização</div></div>
      <div class="card-body" id="d-top-post"></div>
    </div>

    <!-- Histórico -->
    <div class="card">
      <div class="card-header"><div class="card-title">📅 Histórico comparativo</div></div>
      <div class="card-body" id="d-history"></div>
    </div>
  </div>
</div>

<!-- Modal inserir/editar -->
<div class="modal-bg hidden" id="modal-bg">
  <div class="modal">
    <div class="modal-title">📱 Inserir dados do Instagram</div>
    <div class="fr">
      <div class="fg"><label class="fl">🏢 Cliente *</label><select class="fi" id="m-client"><option value="">— selecione —</option></select></div>
      <div class="fg"><label class="fl">📅 Mês *</label><input class="fi" type="month" id="m-month"/></div>
    </div>
    <div class="section-box">
      <div class="section-box-title">📊 Métricas do mês</div>
      <div class="fr">
        <div class="fg"><label class="fl">➕ Seguidores novos</label><input class="fi" type="number" id="m-seg" placeholder="0" min="0"/></div>
        <div class="fg"><label class="fl">👥 Contas alcançadas</label><input class="fi" type="number" id="m-alcance" placeholder="0" min="0"/></div>
      </div>
      <div class="fr">
        <div class="fg"><label class="fl">🔗 Cliques link da bio</label><input class="fi" type="number" id="m-bio" placeholder="0" min="0"/></div>
        <div class="fg"><label class="fl">❤️ Engajamento total</label><input class="fi" type="number" id="m-eng" placeholder="0" min="0"/></div>
      </div>
      <div class="fr">
        <div class="fg"><label class="fl">👁️ Visualizações gerais</label><input class="fi" type="number" id="m-views" placeholder="0" min="0"/></div>
        <div class="fg"><label class="fl">🌍 Views não seguidores</label><input class="fi" type="number" id="m-views-nseg" placeholder="0" min="0"/></div>
      </div>
      <div class="fg"><label class="fl">🔄 Conteúdos compartilhados</label><input class="fi" type="number" id="m-shares" placeholder="0" min="0"/></div>
      <div class="fg"><label class="fl">🏆 Post maior visualização (link)</label><input class="fi" id="m-top-post" placeholder="https://www.instagram.com/p/..."/></div>
    </div>
    <div class="fg"><label class="fl">📝 Observações / Estratégia próximo mês</label><textarea class="fi" id="m-obs" rows="3" placeholder="O que funcionou, o que melhorar..."></textarea></div>
    <div class="fa">
      <button class="btn btn-ghost" onclick="closeModal()">✕ Cancelar</button>
      <button class="btn btn-primary" onclick="saveData()">💾 Salvar dados</button>
    </div>
  </div>
</div>

<script>
// Firebase
const cfg={apiKey:"AIzaSyDVI8-VfUqfQ52cuQNhhEhR9tjgEOpIfKM",authDomain:"flowdesk-794f6.firebaseapp.com",projectId:"flowdesk-794f6",storageBucket:"flowdesk-794f6.firebasestorage.app",messagingSenderId:"866480372119",appId:"1:866480372119:web:0ea282f5e0bc815f59ecd2"};
firebase.initializeApp(cfg);
const db=firebase.firestore();

let clients=[];
let igData={};

// ── Init ──
async function init(){
  try{
    setStatus(false,'Carregando...');
    const[cs,ig]=await Promise.all([db.collection('clients').get(),db.collection('instagram').get()]);
    clients=cs.docs.map(d=>({id:d.id,...d.data()}));
    igData={};ig.docs.forEach(d=>{igData[d.id]=d.data();});
    setStatus(true,'Firebase conectado');
    populateSelectors();
    renderDash();
  }catch(e){
    setStatus(false,'Erro: '+e.message);
    console.error(e);
  }
}

function setStatus(ok,msg){
  const d=document.getElementById('fb-dot'),t=document.getElementById('fb-txt');
  d.className='dot'+(ok?' on':'');t.textContent=msg;
}

// ── Selectors ──
function populateSelectors(){
  const csel=document.getElementById('sel-client');
  const cur=csel.value;
  csel.innerHTML='<option value="">— Selecione o cliente —</option>';
  clients.forEach(c=>csel.innerHTML+=`<option value="${c.id}" ${c.id===cur?'selected':''}>${c.nome}</option>`);
  if(cur)csel.value=cur;

  const msel=document.getElementById('sel-month');
  const now=new Date();
  const curM=msel.value||`${now.getFullYear()}-${String(now.getMonth()+1).padStart(2,'0')}`;
  msel.innerHTML='';
  for(let i=11;i>=0;i--){
    const d=new Date(now.getFullYear(),now.getMonth()-i,1);
    const val=`${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}`;
    msel.innerHTML+=`<option value="${val}" ${val===curM?'selected':''}>${d.toLocaleDateString('pt-BR',{month:'long',year:'numeric'})}</option>`;
  }
}

function onSelChange(){renderDash();}

// ── Modal ──
function openModal(){
  const csel=document.getElementById('m-client');
  csel.innerHTML='<option value="">— selecione —</option>';
  clients.forEach(c=>csel.innerHTML+=`<option value="${c.id}">${c.nome}</option>`);

  const clientId=document.getElementById('sel-client').value;
  const month=document.getElementById('sel-month').value;
  if(clientId)csel.value=clientId;
  document.getElementById('m-month').value=month||new Date().toISOString().slice(0,7);

  // preencher se tiver dados
  const key=clientId&&month?`${clientId}_${month}`:null;
  const d=key?igData[key]:null;
  const fields={seg:'seguidores',alcance:'alcance',bio:'bio',eng:'engajamento',views:'views','views-nseg':'viewsNseg',shares:'shares','top-post':'topPost',obs:'obs'};
  Object.entries(fields).forEach(([elSuffix,prop])=>{
    const el=document.getElementById('m-'+elSuffix);
    if(el)el.value=d&&d[prop]!=null?d[prop]:'';
  });

  document.getElementById('modal-bg').classList.remove('hidden');
}
function closeModal(){document.getElementById('modal-bg').classList.add('hidden');}

async function saveData(){
  const clientId=document.getElementById('m-client').value;
  const month=document.getElementById('m-month').value;
  if(!clientId){alert('Selecione o cliente.');return;}
  if(!month){alert('Selecione o mês.');return;}

  const data={
    clientId,month,
    seguidores:parseInt(document.getElementById('m-seg').value)||0,
    alcance:parseInt(document.getElementById('m-alcance').value)||0,
    bio:parseInt(document.getElementById('m-bio').value)||0,
    engajamento:parseInt(document.getElementById('m-eng').value)||0,
    views:parseInt(document.getElementById('m-views').value)||0,
    viewsNseg:parseInt(document.getElementById('m-views-nseg').value)||0,
    shares:parseInt(document.getElementById('m-shares').value)||0,
    topPost:document.getElementById('m-top-post').value.trim(),
    obs:document.getElementById('m-obs').value.trim(),
    updatedAt:new Date().toISOString()
  };

  const key=`${clientId}_${month}`;
  setStatus(false,'Salvando...');
  try{
    await db.collection('instagram').doc(key).set(data,{merge:true});
    igData[key]=data;
    setStatus(true,'Salvo ✓');
    closeModal();
    // atualiza seletores para mostrar os dados
    document.getElementById('sel-client').value=clientId;
    document.getElementById('sel-month').value=month;
    renderDash();
    alert('✅ Dados salvos com sucesso!');
  }catch(e){
    setStatus(false,'Erro ao salvar');
    alert('Erro ao salvar: '+e.message);
  }
}

// ── Dashboard ──
function renderDash(){
  const clientId=document.getElementById('sel-client').value;
  const month=document.getElementById('sel-month').value;
  const empty=document.getElementById('ig-empty');
  const dash=document.getElementById('ig-dash');

  if(!clientId||!month){empty.classList.remove('hidden');dash.classList.add('hidden');return;}

  const key=`${clientId}_${month}`;
  const d=igData[key];

  if(!d){empty.classList.remove('hidden');dash.classList.add('hidden');return;}
  empty.classList.add('hidden');dash.classList.remove('hidden');

  const taxa=d.alcance>0?((d.engajamento/d.alcance)*100).toFixed(1):'0';
  const pctNseg=d.views>0?((d.viewsNseg/d.views)*100).toFixed(0):'0';

  setText('d-views',(d.views||0).toLocaleString('pt-BR'));
  setText('d-views-sub',`${pctNseg}% de não seguidores`);
  setText('d-alcance',(d.alcance||0).toLocaleString('pt-BR'));
  setText('d-eng',(d.engajamento||0).toLocaleString('pt-BR'));
  setText('d-eng-taxa',`Taxa: ${taxa}%`);
  setText('d-seg','+'+(d.seguidores||0).toLocaleString('pt-BR'));

  // evolução 6 meses
  const[y,m]=month.split('-').map(Number);
  const evData=[];
  for(let i=5;i>=0;i--){
    const dd=new Date(y,m-1-i,1);
    const v=`${dd.getFullYear()}-${String(dd.getMonth()+1).padStart(2,'0')}`;
    const e=igData[`${clientId}_${v}`];
    evData.push({label:dd.toLocaleDateString('pt-BR',{month:'short'}),val:e?e.views||0:0,seg:e?e.seguidores||0:0});
  }
  const maxV=Math.max(...evData.map(d=>d.val),1);
  const ev=document.getElementById('d-evolution');
  if(ev)ev.innerHTML=`<div style="display:flex;align-items:flex-end;gap:6px;height:100px;margin-top:8px">${evData.map(d=>`<div style="flex:1;display:flex;flex-direction:column;align-items:center;gap:4px"><div style="font-size:9px;color:#e1306c;font-weight:700">${d.val>0?d.val.toLocaleString('pt-BR'):''}</div><div style="width:100%;border-radius:6px 6px 0 0;min-height:3px;height:${Math.max((d.val/maxV)*80,3)}px;background:linear-gradient(135deg,#e1306c,#833ab4);opacity:${d.val>0?1:.15}"></div><div style="font-size:9px;color:var(--text3);font-weight:600">${d.label}</div></div>`).join('')}</div>`;

  // insights
  const ins=[];
  const taxaN=parseFloat(taxa);
  if(taxaN>=3)ins.push({e:'🔥',t:`Engajamento excelente: ${taxa}%`,c:'var(--success)'});
  else if(taxaN>=1)ins.push({e:'📊',t:`Engajamento ok (${taxa}%) — reforçar CTAs`,c:'var(--warn)'});
  else if(d.alcance>0)ins.push({e:'⚠️',t:`Engajamento baixo (${taxa}%) — revisar tipo de conteúdo`,c:'var(--danger)'});
  if(parseInt(pctNseg)>50)ins.push({e:'🌍',t:`${pctNseg}% das views são de não seguidores — ótimo alcance orgânico!`,c:'var(--purple)'});
  if(d.seguidores>0)ins.push({e:'📈',t:`+${d.seguidores} novos seguidores este mês`,c:'#2563eb'});
  if(d.bio>0)ins.push({e:'🔗',t:`${d.bio} cliques no link da bio`,c:'#db2777'});
  if(d.shares>0)ins.push({e:'🔄',t:`${d.shares} conteúdos compartilhados`,c:'var(--orange)'});
  if(d.obs)ins.push({e:'📝',t:d.obs,c:'var(--text2)'});
  const insEl=document.getElementById('d-insights');
  if(insEl)insEl.innerHTML=ins.length?ins.map(i=>`<div class="insight"><span class="insight-icon">${i.e}</span><span class="insight-txt" style="color:${i.c}">${i.t}</span></div>`).join(''):'<div style="font-size:12px;color:var(--text3);padding:16px 0;text-align:center">Sem insights disponíveis</div>';

  // cards menores
  const gr=document.getElementById('d-growth');if(gr)gr.innerHTML=hl('➕ Novos seguidores',`+${(d.seguidores||0).toLocaleString('pt-BR')}`,'')+hl('🔄 Compartilhamentos',(d.shares||0).toLocaleString('pt-BR'),'')+hl('🔗 Cliques link bio',(d.bio||0).toLocaleString('pt-BR'),'');
  const eng=document.getElementById('d-engagement');if(eng)eng.innerHTML=hl('❤️ Total interações',(d.engajamento||0).toLocaleString('pt-BR'),'#e1306c')+hl('📊 Taxa engajamento',taxa+'%',taxaN>=3?'var(--success)':taxaN>=1?'var(--warn)':'var(--danger)');
  const reach=document.getElementById('d-reach');if(reach)reach.innerHTML=hl('👁️ Views totais',(d.views||0).toLocaleString('pt-BR'),'')+hl('🌍 Views não seguidores',(d.viewsNseg||0).toLocaleString('pt-BR'),'')+hl('% não seguidores',pctNseg+'%','var(--purple)');

  // top post
  const tp=document.getElementById('d-top-post');
  if(tp)tp.innerHTML=d.topPost?`<div style="display:flex;align-items:center;gap:12px;padding:8px 0"><span style="font-size:13px;font-weight:600">🏆 Post com mais views:</span><a href="${d.topPost}" target="_blank" style="color:var(--purple);font-size:12px;font-weight:600;text-decoration:none;word-break:break-all">🔗 Ver post no Instagram</a></div>`:'<div style="font-size:12px;color:var(--text3);padding:8px 0">Nenhum link cadastrado</div>';

  // histórico
  const entries=Object.values(igData).filter(e=>e.clientId===clientId).sort((a,b)=>b.month.localeCompare(a.month)).slice(0,8);
  const hist=document.getElementById('d-history');
  if(hist)hist.innerHTML=entries.length?`<div style="overflow-x:auto"><table><thead><tr><th>Mês</th><th style="text-align:right">Views</th><th style="text-align:right">Alcance</th><th style="text-align:right">Engaj.</th><th style="text-align:right">Seguidor.</th><th style="text-align:right">Shares</th><th style="text-align:right">Bio</th><th style="text-align:right">Taxa Eng.</th></tr></thead><tbody>${entries.map(e=>{const[ey,em]=e.month.split('-');const lbl=new Date(parseInt(ey),parseInt(em)-1,1).toLocaleDateString('pt-BR',{month:'short',year:'numeric'});const t=e.alcance>0?((e.engajamento/e.alcance)*100).toFixed(1)+'%':'—';return`<tr style="${e.month===month?'background:#f0efff;font-weight:600':''}"><td>${lbl}</td><td style="text-align:right">${(e.views||0).toLocaleString('pt-BR')}</td><td style="text-align:right">${(e.alcance||0).toLocaleString('pt-BR')}</td><td style="text-align:right;color:#e1306c;font-weight:700">${(e.engajamento||0).toLocaleString('pt-BR')}</td><td style="text-align:right;color:var(--success);font-weight:700">+${e.seguidores||0}</td><td style="text-align:right">${e.shares||0}</td><td style="text-align:right">${e.bio||0}</td><td style="text-align:right">${t}</td></tr>`;}).join('')}</tbody></table></div>`:'<div style="font-size:12px;color:var(--text3);padding:12px 0;text-align:center">Sem histórico</div>';
}

function hl(lbl,val,color){return`<div class="hl"><span class="hl-lbl">${lbl}</span><span class="hl-val" style="${color?'color:'+color:''}">${val}</span></div>`;}
function setText(id,v){const el=document.getElementById(id);if(el)el.textContent=v;}

init();
</script>
</body>
</html>
